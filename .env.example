# ==========================================
# DATABASE
# ==========================================
DATABASE_URL="postgresql://username:password@localhost:5432/lms_db?schema=public"

# ==========================================
# BACKEND API
# ==========================================
NODE_ENV="development"
PORT=4000
BACKEND_URL="http://localhost:4000"

# ==========================================
# FRONTEND
# ==========================================
FRONTEND_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:4000/api/v1"

# ==========================================
# JWT AUTHENTICATION
# ==========================================
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-this-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ==========================================
# REDIS
# ==========================================
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""
REDIS_URL="redis://localhost:6379"

# ==========================================
# FILE STORAGE
# ==========================================

# Cloudinary (for images)
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Bunny.net (for videos and PDFs)
BUNNY_API_KEY="your-bunny-api-key"
BUNNY_STORAGE_ZONE="your-storage-zone"
BUNNY_CDN_URL="https://your-cdn-url.b-cdn.net"

# AWS S3 (alternative to Bunny.net)
AWS_ACCESS_KEY_ID="your-access-key"
AWS_SECRET_ACCESS_KEY="your-secret-key"
AWS_REGION="ap-southeast-1"
AWS_S3_BUCKET="your-bucket-name"

# ==========================================
# EMAIL
# ==========================================
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-email-password"
SMTP_FROM="LMS Platform <noreply@lmsplatform.com>"

# ==========================================
# PAYMENT GATEWAYS
# ==========================================

# Dialog Genie
DIALOG_GENIE_MERCHANT_ID=""
DIALOG_GENIE_API_KEY=""

# Frimi
FRIMI_MERCHANT_ID=""
FRIMI_API_KEY=""

# Commercial Bank
COMMERCIAL_BANK_MERCHANT_ID=""
COMMERCIAL_BANK_API_KEY=""

# MintPay
MINTPAY_API_KEY=""

# Koko
KOKO_API_KEY=""

# ==========================================
# ONLINE CLASS INTEGRATION
# ==========================================

# Zoom
ZOOM_API_KEY=""
ZOOM_API_SECRET=""
ZOOM_WEBHOOK_SECRET=""

# Google Meet
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI=""

# ==========================================
# SMS GATEWAY
# ==========================================
SMS_PROVIDER="dialog"
SMS_API_KEY=""
SMS_SENDER_ID="LMS"

# ==========================================
# RATE LIMITING
# ==========================================
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# ==========================================
# LOGGING
# ==========================================
LOG_LEVEL="debug"
LOG_FILE_PATH="logs"

# ==========================================
# CORS
# ==========================================
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:4000"
